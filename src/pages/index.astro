		line-height: 1.15;
		color: var(--charcoal);
		margin-bottom: 1rem;
	}
	.section-title em { font-style: italic; color: var(--sage); }
	.section-body { font-size: 1rem; color: var(--warm-gray); line-height: 1.75; }

	/* ─── ODONTOLOGÍA SERVICES ─── */
	#odontologia { background: var(--ivory); }
	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.2rem;
	}
	.service-card {
		background: var(--white);
		border-radius: 1.3rem;
		padding: 2rem 1.8rem;
		border: 1px solid var(--cream);
		transition: transform 0.3s, box-shadow 0.3s;
		position: relative;
		overflow: hidden;
	}
	.service-card::before {
		content: '';
		position: absolute;
		top: 0; left: 0; right: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--sage), var(--sage-lt));
		opacity: 0;
		transition: opacity 0.3s;
	}
	.service-card:hover { transform: translateY(-4px); box-shadow: 0 16px 50px rgba(0,0,0,0.08); }
	.service-card:hover::before { opacity: 1; }
	.scard-top {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.2rem;
	}
	.scard-num {
		font-family: 'Cormorant Garamond', serif;
		font-size: 0.85rem;
		color: var(--cream);
		font-weight: 600;
		letter-spacing: 0.05em;
	}
	.scard-tag {
		font-size: 0.68rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sage-dk);
		background: rgba(122,158,142,0.1);
		padding: 0.2rem 0.6rem;
		border-radius: 1rem;
	}
	.scard-icon { font-size: 1.8rem; margin-bottom: 0.8rem; }
	.service-card h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.25rem;
		font-weight: 500;
		color: var(--charcoal);
		margin-bottom: 0.5rem;
	}
	.service-card p { font-size: 0.85rem; color: var(--warm-gray); line-height: 1.65; }
	.service-card-cta {
		background: linear-gradient(135deg, var(--charcoal), #3a3a3a);
		border-radius: 1.3rem;
		padding: 2rem 1.8rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.8rem;
	}
	.service-card-cta p { font-size: 0.78rem; color: rgba(247,244,239,0.5); text-transform: uppercase; letter-spacing: 0.08em; }
	.service-card-cta h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.4rem;
		font-weight: 400;
		color: var(--ivory);
	}
	.service-card-cta .btn-primary {
		background: var(--gold);
		color: var(--charcoal);
		font-weight: 600;
		width: fit-content;
	}
	.service-card-cta .btn-primary:hover { background: var(--gold-lt); }

	/* ─── ESTÉTICA ─── */
	#estetica { background: var(--charcoal); overflow: hidden; }
	.estetica-bg {
		position: absolute;
		inset: 0;
		background: radial-gradient(ellipse at 80% 50%, rgba(184,164,196,0.08) 0%, transparent 70%);
		pointer-events: none;
	}
	#estetica .section-title em { color: var(--gold); }
	.estetica-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1px;
		background: rgba(255,255,255,0.06);
		border-radius: 1.5rem;
		overflow: hidden;
	}
	.estetica-card {
		background: rgba(255,255,255,0.03);
		padding: 2.5rem 2rem;
		position: relative;
		transition: background 0.3s;
	}
	.estetica-card:hover { background: rgba(255,255,255,0.06); }
	.ecard-icon { font-size: 1.5rem; margin-bottom: 0.5rem; }
	.ecard-num {
		position: absolute;
		top: 1.5rem; right: 1.8rem;
		font-family: 'Cormorant Garamond', serif;
		font-size: 3rem;
		font-weight: 700;
		color: rgba(255,255,255,0.04);
		line-height: 1;
	}
	.estetica-card h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.2rem;
		font-weight: 500;
		color: var(--ivory);
		margin-bottom: 0.6rem;
		margin-top: 0.5rem;
	}
	.estetica-card p { font-size: 0.83rem; color: rgba(247,244,239,0.5); line-height: 1.65; }
	.ecard-line {
		height: 1px;
		background: linear-gradient(90deg, var(--gold), transparent);
		margin-top: 1.5rem;
		width: 40%;
	}
	.estetica-highlight {
		background: rgba(201,169,110,0.08);
		border: 1px solid rgba(201,169,110,0.2);
		padding: 2.5rem 2rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1rem;
	}
	.eh-icon { font-size: 1.5rem; }
	.estetica-highlight p { font-size: 0.88rem; color: rgba(247,244,239,0.6); line-height: 1.65; }
	.btn-estetica {
		display: inline-flex;
		background: var(--gold);
		color: var(--charcoal);
		padding: 0.7rem 1.4rem;
		border-radius: 2rem;
		font-size: 0.85rem;
		font-weight: 600;
		transition: background 0.25s, transform 0.25s;
		width: fit-content;
	}
	.btn-estetica:hover { background: var(--gold-lt); transform: translateY(-2px); }

	/* ─── NOSOTROS ─── */
	#nosotros .section-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 5rem;
		align-items: center;
	}
	.about-images {
		position: relative;
		height: 500px;
	}
	.about-img-main {
		position: absolute;
		top: 0; left: 0;
		width: 75%; height: 80%;
		object-fit: cover;
		border-radius: 1.5rem;
		box-shadow: 0 30px 80px rgba(0,0,0,0.12);
	}
	.about-img-sec {
		position: absolute;
		bottom: 0; right: 0;
		width: 55%; height: 55%;
		object-fit: cover;
		border-radius: 1.2rem;
		box-shadow: 0 20px 50px rgba(0,0,0,0.1);
		border: 6px solid var(--ivory);
	}
	.about-badge-laser {
		position: absolute;
		top: 50%; right: -1rem;
		transform: translateY(-50%);
		background: var(--white);
		border-radius: 1rem;
		padding: 1rem 1.2rem;
		box-shadow: 0 10px 30px rgba(0,0,0,0.1);
		text-align: center;
		z-index: 2;
	}
	.about-badge-laser strong {
		display: block;
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		color: var(--gold);
		letter-spacing: 0.1em;
	}
	.about-badge-laser span { font-size: 0.68rem; color: var(--warm-gray); text-transform: uppercase; letter-spacing: 0.06em; }
	.about-values {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.8rem;
		margin-top: 2rem;
	}
	.value-card {
		background: var(--cream);
		border-radius: 1rem;
		padding: 1.1rem;
	}
	.value-icon { font-size: 1.2rem; margin-bottom: 0.4rem; }
	.value-card h4 { font-size: 0.85rem; font-weight: 600; color: var(--charcoal); margin-bottom: 0.25rem; }
	.value-card p { font-size: 0.8rem; color: var(--warm-gray); line-height: 1.5; }

	/* ─── GALLERY ─── */
	.gallery-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		margin-bottom: 2.5rem;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		grid-template-rows: 240px 200px;
		gap: 0.8rem;
	}
	.gallery-item {
		border-radius: 1rem;
		overflow: hidden;
		position: relative;
		cursor: pointer;
	}
	.gallery-item:first-child { grid-column: 1 / 3; grid-row: 1 / 2; }
	.gallery-item:nth-child(4) { grid-column: 3 / 5; grid-row: 2 / 3; }
	.gallery-img {
		width: 100%; height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(.16,1,.3,1);
	}
	.gallery-item:hover .gallery-img { transform: scale(1.06); }
	.gallery-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(30,30,30,0.55), transparent);
		opacity: 0;
		transition: opacity 0.35s;
		display: flex;
		align-items: flex-end;
		padding: 1.2rem;
	}
	.gallery-item:hover .gallery-overlay { opacity: 1; }
	.gallery-overlay span { color: var(--white); font-size: 0.82rem; font-weight: 500; }

	/* ─── REVIEWS ─── */
	#resenas { background: var(--ivory); }
	#resenas .section-inner {
		display: grid;
		grid-template-columns: 1fr 2fr;
		gap: 4rem;
		align-items: start;
	}
	.reviews-left { position: sticky; top: 6rem; }
	.overall-score {
		font-family: 'Cormorant Garamond', serif;
		font-size: 5rem;
		font-weight: 300;
		color: var(--charcoal);
		line-height: 1;
		margin-top: 1rem;
	}
	.stars { color: var(--gold); font-size: 1rem; letter-spacing: 2px; margin: 0.5rem 0; }
	.reviews-count { font-size: 0.82rem; color: var(--warm-gray); }
	.rating-bars { margin-top: 1.5rem; }
	.rating-bar-row {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		margin-bottom: 0.5rem;
		font-size: 0.78rem;
		color: var(--warm-gray);
	}
	.rating-bar-track {
		flex: 1;
		height: 4px;
		background: var(--cream);
		border-radius: 3px;
		overflow: hidden;
	}
	.rating-bar-fill {
		height: 100%;
		background: var(--gold);
		border-radius: 3px;
		transition: width 1.2s cubic-bezier(.16,1,.3,1);
	}
	.reviews-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.2rem;
	}
	.review-card {
		background: var(--white);
		border-radius: 1.2rem;
		padding: 1.5rem;
		box-shadow: 0 4px 20px rgba(0,0,0,.04);
		border: 1px solid var(--cream);
	}
	.review-card:nth-child(even) { margin-top: 2rem; }
	.reviewer {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		margin-bottom: 0.8rem;
	}
	.reviewer-avatar {
		width: 38px; height: 38px;
		border-radius: 50%;
		object-fit: cover;
	}
	.reviewer-name { font-size: 0.88rem; font-weight: 600; }
	.reviewer-date { font-size: 0.72rem; color: var(--warm-gray); }
	.review-stars { color: var(--gold); font-size: 0.82rem; margin-bottom: 0.6rem; }
	.review-text { font-size: 0.85rem; color: var(--warm-gray); line-height: 1.65; }
	.review-badge {
		display: inline-block;
		margin-top: 0.8rem;
		font-size: 0.7rem;
		padding: 0.22rem 0.65rem;
		border-radius: 1rem;
		font-weight: 600;
	}
	.dental-badge { background: rgba(122,158,142,0.12); color: var(--sage-dk); }
	.estetica-badge { background: rgba(201,169,110,0.1); color: #9a7a40; }

	/* ─── CONTACT ─── */
	#contacto .section-inner {
		display: grid;
		grid-template-columns: 1fr 1.2fr;
		gap: 5rem;
		align-items: start;
	}
	.contact-detail {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.08);
		font-size: 0.9rem;
	}
	.contact-detail:first-of-type {
		border-top: 1px solid rgba(255,255,255,0.08);
		margin-top: 1.5rem;
	}
	.contact-icon {
		width: 38px; height: 38px;
		background: rgba(255,255,255,0.06);
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-size: 1rem;
		flex-shrink: 0;
	}
	.contact-detail strong { display: block; font-size: 0.72rem; color: rgba(247,244,239,0.4); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.15rem; }
	.contact-detail span { color: rgba(247,244,239,0.8); }
	.contact-specialties {
		display: flex;
		gap: 0.8rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}
	.cs-item {
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.45rem 1rem;
		border-radius: 2rem;
		letter-spacing: 0.06em;
	}
	.cs-dental { background: rgba(122,158,142,0.15); color: var(--sage-lt); border: 1px solid rgba(122,158,142,0.25); }
	.cs-estetica { background: rgba(201,169,110,0.12); color: var(--gold-lt); border: 1px solid rgba(201,169,110,0.25); }
	.form-card {
		background: var(--white);
		border-radius: 1.5rem;
		padding: 2.5rem;
		box-shadow: 0 24px 60px rgba(0,0,0,0.15);
	}
	.form-card h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		font-weight: 500;
		margin-bottom: 1.5rem;
		color: var(--charcoal);
	}
	.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
	.form-group { margin-bottom: 1rem; }
	.form-group label {
		display: block;
		font-size: 0.72rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		color: var(--warm-gray);
		margin-bottom: 0.4rem;
	}
	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 0.8rem 1rem;
		background: var(--ivory);
		border: 1.5px solid transparent;
		border-radius: 0.75rem;
		font-family: 'DM Sans', sans-serif;
		font-size: 0.9rem;
		color: var(--charcoal);
		transition: border-color 0.25s, background 0.25s;
		outline: none;
		appearance: none;
	}
	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus { border-color: var(--gold); background: var(--white); }
	.form-group textarea { resize: vertical; min-height: 100px; }
	.form-submit {
		width: 100%;
		background: var(--charcoal);
		color: var(--white);
		border: none;
		border-radius: 2rem;
		padding: 1rem;
		font-family: 'DM Sans', sans-serif;
		font-size: 0.92rem;
		font-weight: 500;
		cursor: pointer;
		margin-top: 0.5rem;
		transition: background 0.25s, transform 0.25s;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}
	.form-submit:hover { background: var(--sage-dk); transform: translateY(-2px); }
	.form-note { font-size: 0.73rem; color: var(--warm-gray); text-align: center; margin-top: 0.8rem; }

	/* ─── FOOTER ─── */
	footer { background: #141414; color: rgba(247,244,239,0.6); }
	.footer-inner { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem 2rem; }
	.footer-top {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
		border-bottom: 1px solid rgba(255,255,255,0.06);
	}
	.footer-socials { display: flex; gap: 0.6rem; margin-top: 1.2rem; }
	.footer-social {
		width: 32px; height: 32px;
		background: rgba(255,255,255,0.07);
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		font-size: 0.78rem;
		text-transform: uppercase;
		transition: background 0.25s;
		cursor: pointer;
	}
	.footer-social:hover { background: var(--gold); color: var(--charcoal); }
	.footer-col h4 {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ivory);
		margin-bottom: 1.2rem;
	}
	.footer-col ul { list-style: none; }
	.footer-col li { margin-bottom: 0.55rem; }
	.footer-col a { font-size: 0.85rem; color: rgba(247,244,239,0.45); transition: color 0.25s; }
	.footer-col a:hover { color: var(--gold-lt); }
	.footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 2rem;
		font-size: 0.78rem;
		color: rgba(247,244,239,0.3);
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	/* ─── WHATSAPP ─── */
	.wa-btn {
		position: fixed;
		bottom: 2rem; right: 2rem;
		z-index: 999;
		width: 56px; height: 56px;
		background: #25D366;
		border-radius: 50%;
		display: flex; align-items: center; justify-content: center;
		box-shadow: 0 8px 30px rgba(37,211,102,0.45);
		cursor: pointer;
		transition: transform 0.3s, box-shadow 0.3s;
		animation: waPulse 3s ease-in-out infinite;
	}
	.wa-btn:hover { transform: scale(1.12); box-shadow: 0 12px 40px rgba(37,211,102,0.6); animation: none; }
	.wa-btn svg { width: 28px; height: 28px; fill: white; }
	@keyframes waPulse {
		0%, 100% { box-shadow: 0 8px 30px rgba(37,211,102,0.45); }
		50%       { box-shadow: 0 8px 40px rgba(37,211,102,0.75), 0 0 0 10px rgba(37,211,102,0.12); }
	}
	.wa-tooltip {
		position: absolute;
		left: calc(100% + 12px);
		top: 50%;
		transform: translateY(-50%);
		background: var(--charcoal);
		color: var(--white);
		font-size: 0.78rem;
		font-weight: 500;
		white-space: nowrap;
		padding: 0.4rem 0.9rem;
		border-radius: 0.5rem;
		opacity: 0;
		pointer-events: none;
		transition: opacity 0.25s;
	}
	.wa-tooltip::before {
		content: '';
		position: absolute;
		left: -5px; top: 50%;
		transform: translateY(-50%);
		border: 5px solid transparent;
		border-right-color: var(--charcoal);
		border-left: 0;
	}
	.wa-btn:hover .wa-tooltip { opacity: 1; }

	/* ─── ANTES & DESPUÉS ─── */
	#antes-despues { background: var(--charcoal); }
	.ayd-header {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 3rem;
	}
	#antes-despues .section-title { color: var(--ivory); }
	#antes-despues .section-title em { color: var(--gold); }
	#antes-despues .section-body { color: rgba(247,244,239,0.55); }
	.ayd-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.2rem;
	}
	.ayd-card {
		border-radius: 1.2rem;
		overflow: hidden;
		position: relative;
		cursor: pointer;
	}
	.ayd-img-wrap {
		position: relative;
		aspect-ratio: 4/3;
		overflow: hidden;
	}
	.ayd-img-wrap img {
		width: 100%; height: 100%;
		object-fit: cover;
		object-position: center top;
		transition: transform 0.5s cubic-bezier(.16,1,.3,1);
		display: block;
	}
	.ayd-card:hover .ayd-img-wrap img { transform: scale(1.05); }
	.ayd-card-tag {
		position: absolute;
		bottom: 0.9rem;
		left: 0.9rem;
		background: rgba(201,169,110,0.92);
		color: var(--charcoal);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		padding: 0.3rem 0.8rem;
		border-radius: 1rem;
		backdrop-filter: blur(4px);
	}
	.ayd-cta-card {
		border-radius: 1.2rem;
		background: rgba(201,169,110,0.08);
		border: 1px solid rgba(201,169,110,0.2);
		padding: 2rem 1.8rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.8rem;
	}
	.ayd-cta-icon { font-size: 1.5rem; }
	.ayd-cta-card h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.4rem;
		font-weight: 400;
		color: var(--ivory);
	}
	.ayd-cta-card p { font-size: 0.85rem; color: rgba(247,244,239,0.55); line-height: 1.65; }

	/* Variante dental del antes/después */
	#antes-despues-dental { background: var(--ivory); }
	#antes-despues-dental .section-title { color: var(--charcoal); }
	#antes-despues-dental .section-title em { color: var(--sage); }
	#antes-despues-dental .section-body { color: var(--warm-gray); }
	.ayd-card-tag-dental {
		background: rgba(122,158,142,0.9);
		color: var(--white);
	}
	.ayd-cta-card-dental {
		background: var(--cream);
