---
import Layout from '../layouts/Layout.astro';
---

<Layout title='HFD Odontología Láser & Estética Facial | Córdoba' description="HFD Odontología Láser y Estética Facial en Córdoba. Implantología, diseño digital de sonrisa, ortodoncia láser, toxina botulínica, fillers y más.">

	<!-- ═══════════════ NAV ═══════════════ -->
	<nav id="navbar">
		<a href="#inicio" class="nav-logo">HFD<span>·</span></a>
		<ul class="nav-links">
			<li><a href="#odontologia">Odontología</a></li>
			<li><a href="#estetica">Estética Facial</a></li>
			<li><a href="#nosotros">Nosotros</a></li>
			<li><a href="#galeria">Galería</a></li>
			<li><a href="#resenas">Reseñas</a></li>
			<li><a href="#contacto" class="nav-cta">Agendar Cita</a></li>
		</ul>
		<button class="hamburger" id="hamburger" aria-label="Abrir menú">
			<span></span><span></span><span></span>
		</button>
	</nav>

	<!-- Mobile Menu -->
	<div class="mobile-menu" id="mobileMenu">
		<button class="mobile-menu-close" id="menuClose">✕</button>
		<a href="#odontologia" class="mobile-nav-link">Odontología Láser</a>
		<a href="#estetica" class="mobile-nav-link">Estética Facial</a>
		<a href="#nosotros" class="mobile-nav-link">Nosotros</a>
		<a href="#galeria" class="mobile-nav-link">Galería</a>
		<a href="#resenas" class="mobile-nav-link">Reseñas</a>
		<a href="#contacto" class="mobile-nav-link">Agendar Cita</a>
	</div>

	<!-- ═══════════════ HERO ═══════════════ -->
	<section id="inicio">
		<div class="hero-bg-overlay"></div>
		<div class="hero-content">
			<div class="hero-left">
				<div class="hero-badge reveal">Odontología Láser · Estética Facial · Córdoba</div>
				<h1 class="hero-h1 reveal reveal-delay-1">
					Tecnología láser<br>
					para tu sonrisa<br>
					<em>y tu rostro</em>
				</h1>
				<p class="hero-p reveal reveal-delay-2">
					Combinamos odontología de vanguardia con estética facial avanzada. Un solo lugar para tu transformación completa.
				</p>
				<div class="hero-pills reveal reveal-delay-3">
					<span class="pill pill-dental">🦷 Odontología Láser</span>
					<span class="pill pill-estetica">✨ Estética Facial</span>
				</div>
				<div class="hero-actions reveal reveal-delay-3">
					<a href="#contacto" class="btn-primary">Agendar Consulta</a>
					<a href="#odontologia" class="btn-secondary">Ver servicios ↓</a>
				</div>
				<div class="hero-stats reveal reveal-delay-4">
					<div class="stat">
						<div class="stat-num">Láser<span>+</span></div>
						<div class="stat-label">Tecnología avanzada</div>
					</div>
					<div class="stat-divider"></div>
					<div class="stat">
						<div class="stat-num">2<span>en1</span></div>
						<div class="stat-label">Odonto + Estética</div>
					</div>
					<div class="stat-divider"></div>
					<div class="stat">
						<div class="stat-num">4.9<span>★</span></div>
						<div class="stat-label">Calificación</div>
					</div>
				</div>
			</div>
			<div class="hero-right">
				<div class="hero-image-wrap">
					<img
						class="hero-img"
						src="/heroHfd.webp"
						alt="Profesional de HFD"
					/>
				</div>
				<div class="hero-card card-dental">
					<div class="hcard-icon">🦷</div>
					<div>
						<strong>Odontología Láser</strong>
						<span>Sin dolor · Alta precisión</span>
					</div>
				</div>
				<div class="hero-card card-estetica">
					<div class="hcard-icon">✦</div>
					<div>
						<strong>Estética Facial</strong>
						<span>Resultados naturales</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════ SEPARADOR DUAL ═══════════════ -->
	<div class="dual-banner">
		<div class="dual-item dual-dental">
			<span class="dual-icon">🦷</span>
			<span class="dual-label">Odontología Láser</span>
		</div>
		<div class="dual-divider">·</div>
		<div class="dual-item dual-estetica">
			<span class="dual-icon">✦</span>
			<span class="dual-label">Estética & Armonización Facial</span>
		</div>
	</div>

	<!-- ═══════════════ ODONTOLOGÍA ═══════════════ -->
	<section id="odontologia">
		<div class="section-inner">
			<div class="section-header reveal">
				<div class="section-label dental-label">Odontología Láser</div>
				<h2 class="section-title">Tratamientos dentales <em>de última generación</em></h2>
				<p class="section-body" style="max-width:540px;">Aplicamos tecnología láser para procedimientos más precisos, menos invasivos y sin el dolor de los métodos tradicionales.</p>
			</div>
			<div class="services-grid">
				<div class="service-card reveal reveal-delay-1 dental-card">
					<div class="scard-top">
						<div class="scard-num">01</div>
						<div class="scard-tag">Láser</div>
					</div>
					<div class="scard-icon">⚡</div>
					<h3>Odontología Láser</h3>
					<p>Tratamientos odontológicos con láser de alta potencia. Mayor precisión, recuperación más rápida y mínimo sangrado comparado con métodos convencionales.</p>
				</div>
				<div class="service-card reveal reveal-delay-2 dental-card">
					<div class="scard-top">
						<div class="scard-num">02</div>
						<div class="scard-tag">Implantología</div>
					</div>
					<div class="scard-icon">🦷</div>
					<h3>Implantología</h3>
					<p>Solución permanente para dientes faltantes. Implantes de titanio colocados con guías digitales y asistencia láser para máxima precisión y oseointegración.</p>
				</div>
				<div class="service-card reveal reveal-delay-3 dental-card">
					<div class="scard-top">
						<div class="scard-num">03</div>
						<div class="scard-tag">Estética</div>
					</div>
					<div class="scard-icon">😁</div>
					<h3>Diseño Digital de Sonrisa</h3>
					<p>Planificación digital de tu sonrisa ideal. Simulamos el resultado antes del tratamiento para que veas tu transformación antes de comenzar.</p>
				</div>
				<div class="service-card reveal reveal-delay-1 dental-card">
					<div class="scard-top">
						<div class="scard-num">04</div>
						<div class="scard-tag">Ortodoncia</div>
					</div>
					<div class="scard-icon">😊</div>
					<h3>Ortodoncia Asistida por Láser</h3>
					<p>Corrección dental acelerada con asistencia láser. Los movimientos dentales son más rápidos y predecibles, reduciendo el tiempo total de tratamiento.</p>
				</div>
				<div class="service-card reveal reveal-delay-2 dental-card">
					<div class="scard-top">
						<div class="scard-num">05</div>
						<div class="scard-tag">Cirugía</div>
					</div>
					<div class="scard-icon">🔬</div>
					<h3>Cirugía Láser</h3>
					<p>Procedimientos quirúrgicos orales con láser: gingivectomías, frenectomías y más. Menos sangrado, sin suturas en muchos casos, recuperación más veloz.</p>
				</div>
				<div class="service-card-cta reveal reveal-delay-3">
					<p>¿Dudás qué tratamiento necesitás?</p>
					<h3>Primera consulta sin cargo</h3>
					<a href="#contacto" class="btn-primary">Reservar →</a>
				</div>
			</div>
		</div>
	</section>

		<!-- ═══════════════ ANTES & DESPUÉS — ODONTOLOGÍA ═══════════════ -->
	<section id="antes-despues-dental">
		<div class="section-inner">
			<div class="ayd-header">
				<div>
					<div class="section-label dental-label reveal">Resultados Reales</div>
					<h2 class="section-title reveal reveal-delay-1">Antes <em>&amp;</em> Después</h2>
				</div>
				<p class="section-body reveal" style="max-width:380px;">Transformaciones reales con tecnología láser. Cada foto muestra el antes y después del tratamiento dental.</p>
			</div>

			<div class="ayd-grid ayd-grid-dental">

				<!-- Reemplazá cada src con la ruta de la imagen real del cliente -->
				<div class="ayd-card reveal reveal-delay-1">
					<div class="ayd-img-wrap">
						<img src="/odontologia/antesYDespuesOdontologiaUno.webp" alt="Antes y después odontología láser" />
						<span class="ayd-card-tag ayd-card-tag-dental">Odontología Láser</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-2">
					<div class="ayd-img-wrap">
						<img src="/odontologia/antesYDespuesOdontologiaDos.webp" alt="Antes y después implantología" />
						<span class="ayd-card-tag ayd-card-tag-dental">Implantología</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-3">
					<div class="ayd-img-wrap">
						<img src="/odontologia/antesYDespuesOdontologiaTres.webp" alt="Antes y después diseño de sonrisa" />
						<span class="ayd-card-tag ayd-card-tag-dental">Diseño Digital de Sonrisa</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-1">
					<div class="ayd-img-wrap">
						<img src="/odontologia/antesYDespuesOdontologiaCuatro.webp" alt="Antes y después ortodoncia láser" />
						<span class="ayd-card-tag ayd-card-tag-dental">Ortodoncia Asistida por Láser</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-2">
					<div class="ayd-img-wrap">
						<img src="https://placehold.co/800x500/2C2C2C/A8C4B8?font=playfair-display&text=Antes+|+Después" alt="Antes y después cirugía láser" />
						<span class="ayd-card-tag ayd-card-tag-dental">Cirugía Láser</span>
					</div>
				</div>

				<div class="ayd-cta-card ayd-cta-card-dental reveal reveal-delay-3">
					<div class="ayd-cta-icon">🦷</div>
					<h3>¿Querés transformar tu sonrisa?</h3>
					<p>Primera consulta sin cargo. Te explicamos qué tratamiento láser es el ideal para vos.</p>
					<a href="#contacto" class="btn-primary" style="width:fit-content;">Consulta gratuita →</a>
				</div>

			</div>
		</div>
	</section>

	<!-- ═══════════════ ESTÉTICA ═══════════════ -->
	<section id="estetica">
		<div class="estetica-bg"></div>
		<div class="section-inner" style="position:relative;z-index:1;">
			<div class="section-header reveal">
				<div class="section-label estetica-label">Estética & Armonización Facial</div>
				<h2 class="section-title" style="color:var(--ivory);">Tu mejor versión, <em>de forma natural</em></h2>
				<p class="section-body" style="max-width:560px;color:rgba(247,244,239,0.6);">Tratamientos mínimamente invasivos para realzar y armonizar tu rostro con resultados 100% naturales y seguros.</p>
			</div>
			<div class="estetica-grid">
				<div class="estetica-card reveal reveal-delay-1">
					<div class="ecard-icon">💉</div>
					<div class="ecard-num">01</div>
					<h3>Toxina Botulínica</h3>
					<p>Reducción de arrugas de expresión con resultados naturales. Tratamiento seguro y sin tiempo de recuperación para lucir descansada/o y juvenil.</p>
					<div class="ecard-line"></div>
				</div>
				<div class="estetica-card reveal reveal-delay-2">
					<div class="ecard-icon">✦</div>
					<div class="ecard-num">02</div>
					<h3>Fillers con Ácido Hialurónico</h3>
					<p>Relleno y voluminización de labios, pómulos, ojeras y más. Resultados inmediatos, reversibles y completamente personalizados a tu anatomía.</p>
					<div class="ecard-line"></div>
				</div>
				<div class="estetica-card reveal reveal-delay-3">
					<div class="ecard-icon">🌿</div>
					<div class="ecard-num">03</div>
					<h3>Bioestimulación de Colágeno y Elastina</h3>
					<p>Estimulación natural de la producción de colágeno y elastina para una piel más firme, luminosa y rejuvenecida desde adentro hacia afuera.</p>
					<div class="ecard-line"></div>
				</div>
				<div class="estetica-card reveal reveal-delay-1">
					<div class="ecard-icon">⚡</div>
					<div class="ecard-num">04</div>
					<h3>Láser — Estimulación de Colágeno</h3>
					<p>Tecnología láser para estimular la producción de colágeno y elastina. Mejora la textura, firmeza y apariencia general de la piel sin cirugía.</p>
					<div class="ecard-line"></div>
				</div>
				<div class="estetica-card reveal reveal-delay-2">
					<div class="ecard-icon">🩸</div>
					<div class="ecard-num">05</div>
					<h3>PRP — Plasma Rico en Plaquetas</h3>
					<p>Tratamiento regenerativo con tu propio plasma. Estimula la renovación celular, mejora la calidad de la piel y acelera la recuperación de forma 100% natural.</p>
					<div class="ecard-line"></div>
				</div>
				<div class="estetica-highlight reveal reveal-delay-3">
					<div class="eh-icon">✦</div>
					<p>Todos nuestros tratamientos estéticos son realizados por profesionales especializados con protocolos de seguridad certificados.</p>
					<a href="#contacto" class="btn-estetica">Consulta sin cargo →</a>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════ ANTES & DESPUÉS ═══════════════ -->
	<section id="antes-despues">
		<div class="section-inner">
			<div class="ayd-header">
				<div>
					<div class="section-label estetica-label reveal">Resultados Reales</div>
					<h2 class="section-title reveal reveal-delay-1">Antes <em>&amp;</em> Después</h2>
				</div>
				<p class="section-body reveal" style="max-width:380px;">Imágenes reales de nuestros pacientes. Cada foto muestra la transformación antes y después del tratamiento.</p>
			</div>

			<div class="ayd-grid">

				<!-- Reemplazá cada src con la ruta de la imagen real del cliente -->
				<div class="ayd-card reveal reveal-delay-1">
					<div class="ayd-img-wrap">
						<img src="/facial/antesYDespuesFacialUno.webp" alt="Antes y después toxina botulínica" />
						<span class="ayd-card-tag">Toxina Botulínica</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-2">
					<div class="ayd-img-wrap">
						<img src="/facial/antesYDespuesFacialDos.webp" alt="Antes y después fillers" />
						<span class="ayd-card-tag">Fillers con Ácido Hialurónico</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-3">
					<div class="ayd-img-wrap">
						<img src="/facial/antesYDespuesFacialTres.webp" alt="Antes y después bioestimulación" />
						<span class="ayd-card-tag">Bioestimulación de Colágeno</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-4">
					<div class="ayd-img-wrap">
						<img src="/facial/antesYDespuesFacialCuatro.webp" alt="Antes y después láser colágeno" />
						<span class="ayd-card-tag">Láser — Estimulación de Colágeno</span>
					</div>
				</div>

				<div class="ayd-card reveal reveal-delay-1">
					<div class="ayd-img-wrap">
						<img src="https://placehold.co/800x500/1E1E1E/C9A96E?font=playfair-display&text=Antes+|+Después" alt="Antes y después PRP" />
						<span class="ayd-card-tag">PRP — Plasma Rico en Plaquetas</span>
					</div>
				</div>

				<div class="ayd-cta-card reveal reveal-delay-2">
					<div class="ayd-cta-icon">✦</div>
					<h3>¿Querés ver tu transformación?</h3>
					<p>Agendá una consulta sin cargo y te asesoramos sobre el tratamiento ideal para vos.</p>
					<a href="#contacto" class="btn-estetica">Consulta gratuita →</a>
				</div>

			</div>
		</div>
	</section>

		<!-- ═══════════════ NOSOTROS ═══════════════ -->
	<section id="nosotros">
		<div class="section-inner">
			<div class="about-images reveal from-left">
				<img
					class="about-img-main"
					src="/about/aboutHfd.webp"
					alt="Clínica HFD moderna"
				/>
				<img
					class="about-img-sec"
					src="/about/aboutHfdDos.webp"
					alt="Profesional HFD"
				/>
				<div class="about-badge-laser">
					<strong>LÁSER</strong>
					<span>Certificado</span>
				</div>
			</div>
			<div>
				<div class="section-label reveal">Sobre HFD</div>
				<h2 class="section-title reveal reveal-delay-1">
					Tecnología de punta<br>
					<em>en Córdoba</em>
				</h2>
				<p class="section-body reveal reveal-delay-2">
					HFD Odontología Láser y Estética Facial nació con una propuesta única: reunir en un mismo lugar la odontología de última generación con los tratamientos de estética facial más avanzados. Todo bajo protocolos de seguridad certificados.
				</p>
				<p class="section-body reveal reveal-delay-3" style="margin-top:0.8rem;">
					La tecnología láser atraviesa todo nuestro trabajo: desde los tratamientos dentales hasta la estimulación de colágeno en estética. Menos dolor, más precisión, mejores resultados.
				</p>
				<div class="about-values reveal reveal-delay-4">
					<div class="value-card">
						<div class="value-icon">⚡</div>
						<h4>Tecnología Láser</h4>
						<p>Equipamiento de última generación para tratamientos más precisos y confortables.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">🎯</div>
						<h4>Doble Especialidad</h4>
						<p>Odontología y estética facial en un mismo espacio con el mismo estándar de excelencia.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">🔒</div>
						<h4>Protocolos Seguros</h4>
						<p>Todos los procedimientos bajo estrictos protocolos de bioseguridad certificados.</p>
					</div>
					<div class="value-card">
						<div class="value-icon">🌿</div>
						<h4>Resultados Naturales</h4>
						<p>Nuestro objetivo es realzar tu belleza natural, nunca alterarla.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════ GALERÍA ═══════════════ -->
	<section id="galeria" style="background:var(--cream);">
		<div class="section-inner">
			<div class="gallery-header">
				<div>
					<div class="section-label reveal">Instalaciones</div>
					<h2 class="section-title reveal reveal-delay-1">Nuestra <em>clínica</em></h2>
				</div>
				<p class="section-body reveal" style="max-width:320px;">Diseñada para brindarte comodidad, higiene y tecnología en cada rincón.</p>
			</div>
			<div class="gallery-grid">
				<div class="gallery-item reveal scale-up">
					<img class="gallery-img" src="/clinica/espera.webp" alt="Sala de espera" />
					<div class="gallery-overlay"><span>Sala de espera</span></div>
				</div>
				<div class="gallery-item reveal scale-up reveal-delay-1">
					<img class="gallery-img" src="/clinica/consultorioUno.webp" alt="Consultorio" />
					<div class="gallery-overlay"><span>Consultorio láser</span></div>
				</div>
				<div class="gallery-item reveal scale-up reveal-delay-2">
					<img class="gallery-img" src="/clinica/equipamiento.webp" alt="Equipamiento" />
					<div class="gallery-overlay"><span>Equipamiento digital</span></div>
				</div>
				<div class="gallery-item reveal scale-up reveal-delay-3">
					<img class="gallery-img" src="/clinica/sala.webp" alt="Sala" />
					<div class="gallery-overlay"><span>Sala</span></div>
				</div>
				<div class="gallery-item reveal scale-up reveal-delay-1">
					<img class="gallery-img" src="/clinica/recepcion.webp" alt="Recepción" />
					<div class="gallery-overlay"><span>Recepción</span></div>
				</div>
				<div class="gallery-item reveal scale-up reveal-delay-2">
					<img class="gallery-img" src="/clinica/laboratorio.webp" alt="Laboratorio" />
					<div class="gallery-overlay"><span>Laboratorio dental</span></div>
				</div>
			</div>
		</div>
	</section>

	<!-- ═══════════════ RESEÑAS ═══════════════ -->
	<section id="resenas">
		<div class="section-inner">
			<div class="reviews-left">
				<div class="section-label reveal">Opiniones</div>
				<h2 class="section-title reveal reveal-delay-1">Lo que dicen<br><em>nuestros pacientes</em></h2>
				<div class="overall-score reveal reveal-delay-2">4.9</div>
				<div class="stars reveal reveal-delay-3">★★★★★</div>
				<p class="reviews-count reveal reveal-delay-3">Basado en reseñas verificadas</p>
				<div class="rating-bars reveal reveal-delay-4">
					<div class="rating-bar-row">
						<span>5★</span>
						<div class="rating-bar-track"><div class="rating-bar-fill" data-width="92" style="width:0%"></div></div>
						<span>92%</span>
					</div>
					<div class="rating-bar-row">
						<span>4★</span>
						<div class="rating-bar-track"><div class="rating-bar-fill" data-width="6" style="width:0%"></div></div>
						<span>6%</span>
					</div>
					<div class="rating-bar-row">
						<span>3★</span>
						<div class="rating-bar-track"><div class="rating-bar-fill" data-width="2" style="width:0%"></div></div>
						<span>2%</span>
					</div>
				</div>
			</div>
			<div class="reviews-grid">
				<div class="review-card reveal">
					<div class="reviewer">
